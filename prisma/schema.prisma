generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  TEACHER
  STUDENT
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
  MATH
}

enum TimerType {
  PER_QUIZ
  PER_QUESTION
}

enum QuestionSelectionMode {
  ALL
  RANDOM
  MANUAL
}

enum RandomQuestionScope {
  SESSION
  PARTICIPANT
}

enum SessionStatus {
  WAITING
  ACTIVE
  ENDED
}

enum ViolationType {
  FULLSCREEN_EXIT
  TAB_SWITCH
  RIGHT_CLICK
  DEVTOOLS
  COPY_PASTE
  SCREENSHOT_ATTEMPT
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  emailVerifiedAt DateTime?
  role         Role     @default(STUDENT)
  avatar       String   @default("Wave")
  isActive     Boolean  @default(true)
  lastSeenAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quizzes      Quiz[]
  participants Participant[]
  verificationCodes EmailVerificationCode[]
  passwordResetTokens PasswordResetToken[]
  patchNoteReads PatchNoteRead[]

  @@index([lastSeenAt])
}

model EmailVerificationCode {
  id        String   @id @default(cuid())
  codeHash  String
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, codeHash])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tokenHash])
}

model Quiz {
  id                 String    @id @default(cuid())
  title              String
  description        String?
  timerType          TimerType @default(PER_QUIZ)
  duration           Int       @default(300) // seconds
  questionSelectionMode QuestionSelectionMode @default(ALL)
  randomQuestionScope RandomQuestionScope @default(SESSION)
  questionDrawCount  Int?
  randomizeQuestions Boolean   @default(false)
  randomizeAnswers   Boolean   @default(false)
  antiCheatEnabled   Boolean   @default(false)
  allowSkip          Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  teacherId String
  teacher   User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  questions Question[]
  sessions  QuizSession[]
}

model Question {
  id             String       @id @default(cuid())
  type           QuestionType @default(MCQ)
  topic          String       @default("General")
  text           String
  order          Int          @default(0)
  includedInQuiz Boolean      @default(true)
  mathTolerance  Float        @default(0)

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  options Option[]
  answers Answer[]

  @@index([quizId])
}

model Option {
  id        String  @id @default(cuid())
  text      String
  isCorrect Boolean @default(false)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuizSession {
  id        String        @id @default(cuid())
  code      String        @unique
  status    SessionStatus @default(WAITING)
  startedAt DateTime?
  endedAt   DateTime?
  archivedAt DateTime?
  createdAt DateTime      @default(now())

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  participants Participant[]
  violations   ViolationLog[]
}

model Participant {
  id                String   @id @default(cuid())
  score             Int      @default(0)
  isFinished        Boolean  @default(false)
  joinedAt          DateTime @default(now())
  quizStartedAt     DateTime?  // wall-clock moment the student first entered ACTIVE state
  lastQuestionIndex Int      @default(0) // last question index they were on

  sessionId String
  session   QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  answers    Answer[]
  violations ViolationLog[]

  @@index([sessionId])
  @@index([userId, sessionId])
}

model Answer {
  id         String   @id @default(cuid())
  answerText String
  isCorrect  Boolean  @default(false)
  answeredAt DateTime @default(now())

  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([participantId, questionId])
  @@index([participantId])
  @@index([questionId])
}

model ViolationLog {
  id        String        @id @default(cuid())
  type      ViolationType
  count     Int           @default(1)
  note      String?
  timestamp DateTime      @default(now())

  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  sessionId String
  session   QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([participantId])
  @@index([participantId, timestamp])
  @@index([sessionId])
}

model PatchNote {
  id        String   @id @default(cuid())
  title     String
  body      String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reads PatchNoteRead[]
}

model PatchNoteRead {
  id      String   @id @default(cuid())
  readAt  DateTime @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  patchNoteId String
  patchNote   PatchNote @relation(fields: [patchNoteId], references: [id], onDelete: Cascade)

  @@unique([userId, patchNoteId])
  @@index([userId])
  @@index([patchNoteId])
}
